class Solution {
    public int removeDuplicates(int[] nums) {
        if(nums.length<=0){
            return nums.length;
        }
        int k=2;
        for(int i=2;i<nums.length;i++){
            if(nums[i]!=nums[k-2]){
                nums[k++]=nums[i];
            }
        }
        return k;
        
    }
}


Input
nums =
[1,1,1,2,2,3]
Output
[1,1,2,2,3]
Expected
[1,1,2,2,3]
