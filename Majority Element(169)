class Solution {
    public int majorityElement(int[] nums) {
        int canditate=0;
        int count=0;
        for(int num:nums){
            if(count==0){
                canditate=num;
            }
            count +=(num==canditate)?1:-1;
        }
        return canditate;
    }
}




