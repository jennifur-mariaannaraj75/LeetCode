class Solution {
    public int jump(int[] nums) {
        int jumps=0;
        int farthest=0;
        int currentEnd=0;
        for(int i=0;i<nums.length-1;i++){
            farthest=Math.max(farthest,nums[i]+i);

            if(i==currentEnd){
                jumps++;
                currentEnd=farthest;
            }
        }
        return jumps;

    }
}



Input
nums =
[2,3,1,1,4]
Output
2
